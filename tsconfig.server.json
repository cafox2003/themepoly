{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "dist-server",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["server/**/*.ts", "src/engine/**/*.ts", "src/multiplayer/**/*.ts"],
  "exclude": ["src/**/*.test.ts"]
}
